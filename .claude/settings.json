{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,sys,subprocess; f=json.load(sys.stdin).get('tool_input',{}).get('file_path',''); f.endswith('.py') and subprocess.run([sys.executable,'-m','ruff','format',f])\" 2>/dev/null || true",
            "statusMessage": "ruff format"
          }
        ]
      }
    ]
  }
}
